# File: .env.deploy.example
# Description: Template for .env.deploy — the (git-ignored) credentials + target file that
#   scripts/deploy-verpex.sh reads to upload the production dist/ to the Verpex shared host.
#   Copy this to `.env.deploy`, fill in the real values, and keep `.env.deploy` OUT of git
#   (.gitignore covers it). NEVER commit real credentials. The deploy script fails loudly if
#   .env.deploy is missing or if VERPEX_REMOTE_PATH is unset — there is no hardcoded fallback.
# Author: Libor Ballaty (with assistant)
# Created: 2026-07-10
#
# Operator steps to go live (verpex-deploy plan step):
#   1. cp .env.deploy.example .env.deploy   &&   fill in the values below.
#   2. Verify the dry run first:  npm run deploy -- --dry-run   (needs NO creds; uploads nothing).
#   3. Real deploy:  npm run deploy          (requires .env.deploy; uploads dist/ ONLY).
#   4. In the Supabase dashboard (project gxlrmdfqcqimwwplrdgd) set:
#        Authentication -> URL Configuration -> Site URL       = https://falamadeira.searchingfool.com
#        Authentication -> URL Configuration -> Redirect URLs += https://falamadeira.searchingfool.com/**
#      (magic-link / OAuth redirects break until the domain is on the allow-list.)

# --- Connection ---------------------------------------------------------------------------------
# SFTP/SSH host for the Verpex account (e.g. host.verpex.example or the server IP).
VERPEX_HOST=

# SSH/SFTP username for the account.
VERPEX_USER=

# Auth: EITHER a private key path (preferred) OR a password. If VERPEX_SSH_KEY is set it is used
# and the password is ignored. Password auth over sftp/scp is non-interactive only if sshpass is
# installed; the key path is the recommended, sshpass-free route.
VERPEX_SSH_KEY=
VERPEX_PASS=

# Optional SSH/SFTP port (default 22).
VERPEX_PORT=22

# --- Target (SCOPED — this is the ONLY directory we ever write to) ------------------------------
# Absolute remote path to the falamadeira.searchingfool.com DOCUMENT ROOT directory, and NOTHING
# above it. Example: /home/<user>/falamadeira.searchingfool.com  (or the host's public_html-style
# path for that subdomain). The deploy script REFUSES to run if this is empty, and guards that it
# looks like the scoped falamadeira directory (see scripts/deploy-verpex.sh).
VERPEX_REMOTE_PATH=
