#!/usr/bin/env bash
# File: .githooks/pre-commit
# Description: FalaMadeira branch-discipline guard (AGENTS.md §7). Blocks a commit if the current
#   worktree is on the wrong branch (base checkout must be develop; *-release worktree must be main).
#   Prevents agents in the shared multi-agent checkout from accidentally committing to the wrong
#   branch. Enable once per machine with: git config core.hooksPath .githooks
# Author: Lane B (with assistant)
# Created: 2026-07-14
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
if [ -f "${ROOT}/scripts/check-branch-discipline.mjs" ]; then
  node "${ROOT}/scripts/check-branch-discipline.mjs" --current || exit 1
fi

# Version consistency VALIDATE (never mutate — the bump itself happens in ship.sh at the release
# cut). Fails the commit if VERSION and the package.json version literal have drifted, catching a
# manual edit to one but not the other. Both files must exist to check.
if [ -f "${ROOT}/VERSION" ] && [ -f "${ROOT}/package.json" ]; then
  file_ver="$(tr -d ' \t\n\r' < "${ROOT}/VERSION")"
  pkg_ver="$(node -e "process.stdout.write(require('${ROOT}/package.json').version || '')" 2>/dev/null || echo '')"
  if [ -n "${file_ver}" ] && [ -n "${pkg_ver}" ] && [ "${file_ver}" != "${pkg_ver}" ]; then
    echo "pre-commit: VERSION (${file_ver}) != package.json version (${pkg_ver})." >&2
    echo "            reconcile with ~/.ai-dev-dotfiles/tools/version-bump.py before committing." >&2
    exit 1
  fi
fi
