        "dialogues": [
          {
            "id": "dlg-sit-d50-at-the-market-1",
            "title": "Buying Fruit and Vegetables",
            "context": "A customer is buying fruit and vegetables at a stall in the Mercado dos Lavradores in Funchal.",
            "lines": [
              {
                "speaker": "Vendedor",
                "voice_type": "service",
                "text": "Diga! Posso ajudar?"
              },
              {
                "speaker": "Cliente",
                "voice_type": "local",
                "text": "Bom dia. Queria um quilo de bananas, por favor."
              },
              {
                "speaker": "Vendedor",
                "voice_type": "service",
                "text": "Claro. São estas, estão ótimas hoje."
              },
              {
                "speaker": "Cliente",
                "voice_type": "local",
                "text": "Pois, parecem boas. E quanto custa o quilo?"
              },
              {
                "speaker": "Vendedor",
                "voice_type": "service",
                "text": "São dois euros e cinquenta."
              },
              {
                "speaker": "Cliente",
                "voice_type": "local",
                "text": "Está bem. E queria também meio quilo de semilhas."
              },
              {
                "speaker": "Vendedor",
                "voice_type": "service",
                "text": "Meio quilo de semilhas. Mais alguma coisa?"
              },
              {
                "speaker": "Cliente",
                "voice_type": "local",
                "text": "Não, é tudo. Quanto é que fica?"
              },
              {
                "speaker": "Vendedor",
                "voice_type": "service",
                "text": "Então, um quilo de bananas e meio quilo de semilhas... Fica três euros e setenta e cinco."
              },
              {
                "speaker": "Cliente",
                "voice_type": "local",
                "text": "Aqui tem. Obrigado!"
              },
              {
                "speaker": "Vendedor",
                "voice_type": "service",
                "text": "Eu é que agradeço. Volte sempre!"
              }
            ]
          },
          {
            "id": "dlg-sit-d50-at-the-market-2",
            "title": "Asking about Fish",
            "context": "A customer is asking about fresh fish at a busy fish stall in the market, with some background noise.",
            "lines": [
              {
                "speaker": "Peixeira",
                "voice_type": "noisy",
                "text": "Olá! O que deseja?"
              },
              {
                "speaker": "Cliente",
                "voice_type": "older",
                "text": "Bom dia. O peixe-espada está fresco hoje?"
              },
              {
                "speaker": "Peixeira",
                "voice_type": "noisy",
                "text": "Fresco, fresquíssimo! Acabou de chegar!"
              },
              {
                "speaker": "Cliente",
                "voice_type": "older",
                "text": "Ah, que bom. E quanto custa o quilo?"
              },
              {
                "speaker": "Peixeira",
                "voice_type": "noisy",
                "text": "Está a dez euros o quilo. Posso preparar um para si?"
              },
              {
                "speaker": "Cliente",
                "voice_type": "older",
                "text": "Sim, por favor. Um bocado grande, p'ra dois."
              },
              {
                "speaker": "Peixeira",
                "voice_type": "noisy",
                "text": "P'ra já! Quer que o amanhe?"
              },
              {
                "speaker": "Cliente",
                "voice_type": "older",
                "text": "Sim, por favor. Obrigado!"
              }
            ]
          }
        ],
        "cultural_notes": [
          {
            "title": "Market Etiquette in Madeira",
            "body": "When shopping at a market stall in Madeira, it's common to greet the vendor ('Bom dia'/'Boa tarde') and ask about the freshness of produce ('Está fresco/a hoje?' or 'Estão frescos/as hoje?'). It's considered polite to ask the vendor to pick items for you rather than touching them yourself, especially for fruits and vegetables. Don't be afraid to ask for local specialties like 'semilhas' (potatoes) or 'peixe-espada' (black scabbard fish)."
          },
          {
            "title": "Quantities and Payment",
            "body": "Quantities are usually requested in 'quilos' (kilos), 'meio quilo' (half kilo), or 'dúzias' (dozens). For small items like a single avocado, you might ask for 'uma unidade' or 'um abacate'. After selecting your items, the vendor will usually ask 'Mais alguma coisa?' (Anything else?). When finished, say 'É tudo, obrigado/a' and ask 'Quanto é que fica?' to get the total. Cash is often preferred, but many stalls now accept card payments."
          }
        ],
