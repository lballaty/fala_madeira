        "dialogues": [
          {
            "id": "dlg-sit-social-making-plans-weekend-1",
            "title": "Planning a Levada Walk",
            "context": "Two friends, Maria and João, are chatting casually, planning something for the weekend in Madeira.",
            "lines": [
              {
                "speaker": "João",
                "voice_type": "local",
                "text": "Então, Maria, o que é que te apetece fazer este fim de semana?",
                "translation": "So, Maria, what do you feel like doing this weekend?"
              },
              {
                "speaker": "Maria",
                "voice_type": "younger",
                "text": "Hmm... Apetece-me ir dar um passeio. Que tal uma levada?",
                "translation": "Hmm... I feel like going for a walk. How about a levada?"
              },
              {
                "speaker": "João",
                "voice_type": "local",
                "text": "Boa ideia! A da Ribeira da Janela, talvez? É bonita.",
                "translation": "Good idea! The one at Ribeira da Janela, maybe? It's beautiful."
              },
              {
                "speaker": "Maria",
                "voice_type": "younger",
                "text": "Sim, pode ser. Sábado de manhã, às nove e meia?",
                "translation": "Yes, that can be. Saturday morning, at half past nine?"
              },
              {
                "speaker": "João",
                "voice_type": "local",
                "text": "P'ra mim, tá ótimo! Encontramo-nos lá à entrada?",
                "translation": "For me, that's great! Shall we meet there at the entrance?"
              },
              {
                "speaker": "Maria",
                "voice_type": "younger",
                "text": "Combinado! Depois mando mensagem a confirmar tudo.",
                "translation": "Agreed! I'll send a message to confirm everything later."
              }
            ]
          }
        ],
        "cultural_notes": [
          {
            "title": "Levadas: Madeira's Unique Footpaths",
            "body": "Levadas are ancient irrigation channels unique to Madeira, originally built to carry water from the north to the drier south of the island. Today, many have become popular walking trails, offering stunning views and a chance to experience Madeira's natural beauty. When suggesting activities, a 'levada walk' is a very common and appreciated option."
          },
          {
            "title": "Informal Planning with 'Tu'",
            "body": "When making plans with friends or peers in Portugal, it's very common and natural to use the informal 'tu' form. Expressions like 'apetece-te' (do you feel like), 'que horas te dão jeito' (what time suits you), and 'encontramo-nos' (shall we meet) are standard for casual arrangements. Confirming via message ('mando mensagem a confirmar') is also typical after a phone call."
          }
        ],
        "roleplay": {
          "scenario": "You are calling a friend in Madeira to make plans for the upcoming weekend. You want to suggest either going for coffee or a walk.",
          "difficulty": 2,
          "entry_node": "rp-weekend-start",
          "nodes": [
            {
              "id": "rp-weekend-start",
              "npc_text": "Olá! Tudo bem? O que é que se passa?",
              "npc_translation": "Hi! All good? What's up?",
              "npc_voice_type": "younger",
              "options": [
                {
                  "text": "Queria combinar qualquer coisa para o fim de semana.",
                  "translation": "I wanted to arrange something for the weekend.",
                  "feedback": "Good, you've stated your intention clearly.",
                  "next": "rp-weekend-suggest-activity"
                },
                {
                  "text": "Estava a pensar no que fazer no sábado.",
                  "translation": "I was thinking about what to do on Saturday.",
                  "feedback": "This is also good, specifying the day.",
                  "next": "rp-weekend-suggest-activity"
                }
              ]
            },
            {
              "id": "rp-weekend-suggest-activity",
              "npc_text": "Ah, boa! O que é que te apetece?",
              "npc_translation": "Oh, good! What do you feel like doing?",
              "npc_voice_type": "younger",
              "options": [
                {
                  "text": "Que tal irmos beber um café?",
                  "translation": "How about we go for a coffee?",
                  "feedback": "A simple and common suggestion. 'Irmos' is the correct informal form.",
                  "next": "rp-weekend-agree-coffee"
                },
                {
                  "text": "Apetece-me ir dar um passeio, talvez uma levada.",
                  "translation": "I feel like going for a walk, maybe a levada.",
                  "feedback": "Excellent, a very Madeiran suggestion!",
                  "next": "rp-weekend-agree-walk"
                }
              ]
            },
            {
              "id": "rp-weekend-agree-coffee",
              "npc_text": "Sim, pode ser! Que horas te dão jeito?",
              "npc_translation": "Yes, that can be! What time suits you?",
              "npc_voice_type": "younger",
              "options": [
                {
                  "text": "Sábado de manhã, às dez?",
                  "translation": "Saturday morning, at ten?",
                  "feedback": "Good, clear suggestion of day and time.",
                  "next": "rp-weekend-suggest-place-coffee"
                },
                {
                  "text": "Domingo à tarde, pelas quatro?",
                  "translation": "Sunday afternoon, around four?",
                  "feedback": "Another good option, using 'pelas' for 'around'.",
                  "next": "rp-weekend-suggest-place-coffee"
                }
              ]
            },
            {
              "id": "rp-weekend-agree-walk",
              "npc_text": "Sim, adoro as levadas! Quando é que podíamos ir?",
              "npc_translation": "Yes, I love the levadas! When could we go?",
              "npc_voice_type": "younger",
              "options": [
                {
                  "text": "Que tal sábado de manhã, bem cedo?",
                  "translation": "How about Saturday morning, quite early?",
                  "feedback": "Good, 'bem cedo' is a natural way to say 'quite early'.",
                  "next": "rp-weekend-suggest-place-walk"
                },
                {
                  "text": "Domingo à tarde, se não estiver muito calor?",
                  "translation": "Sunday afternoon, if it's not too hot?",
                  "feedback": "Excellent, adding a condition makes it very natural.",
                  "next": "rp-weekend-suggest-place-walk"
                }
              ]
            },
            {
              "id": "rp-weekend-suggest-place-coffee",
              "npc_text": "Sim, essa hora é perfeita. Onde é que nos encontramos?",
              "npc_translation": "Yes, that time is perfect. Where shall we meet?",
              "npc_voice_type": "younger",
              "options": [
                {
                  "text": "No café perto do mercado?",
                  "translation": "At the café near the market?",
                  "feedback": "Clear suggestion for a meeting point.",
                  "next": "rp-weekend-confirm"
                },
                {
                  "text": "Naquela pastelaria nova?",
                  "translation": "At that new pastry shop?",
                  "feedback": "Good, using 'naquela' to refer to a known place.",
                  "next": "rp-weekend-confirm"
                }
              ]
            },
            {
              "id": "rp-weekend-suggest-place-walk",
              "npc_text": "Sim, ótimo! Onde é que nos encontramos?",
              "npc_translation": "Yes, great! Where shall we meet?",
              "npc_voice_type": "younger",
              "options": [
                {
                  "text": "À entrada da levada, como da última vez?",
                  "translation": "At the entrance to the levada, like last time?",
                  "feedback": "Good, referencing a previous meeting is natural.",
                  "next": "rp-weekend-confirm"
                },
                {
                  "text": "Podíamos ir no meu carro. Eu apanho-te em casa.",
                  "translation": "We could go in my car. I'll pick you up at home.",
                  "feedback": "A practical suggestion, showing initiative.",
                  "next": "rp-weekend-confirm"
                }
              ]
            },
            {
              "id": "rp-weekend-confirm",
              "npc_text": "Perfeito! Então está combinado.",
              "npc_translation": "Perfect! So it's arranged.",
              "npc_voice_type": "younger",
              "options": [
                {
                  "text": "Está combinado! Depois mando mensagem a confirmar.",
                  "translation": "It's arranged! I'll send a message to confirm later.",
                  "feedback": "Great, you've confirmed and mentioned the follow-up message."
                },
                {
                  "text": "Pois é! Até lá.",
                  "translation": "Indeed! See you then.",
                  "feedback": "A simple and friendly way to end the call."
                }
              ]
            }
          ]
        },
        "mission": {
          "title": "Call a friend to make weekend plans",
          "prep": [
